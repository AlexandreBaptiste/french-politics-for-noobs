---
const navItems = [
  { href: "/partis",             fr: "Partis",       en: "Parties"    },
  { href: "/institutions",       fr: "Institutions", en: "Institutions"},
  { href: "/systeme-electoral",  fr: "Elections",    en: "Elections"   },
  { href: "/chronologie",        fr: "Chronologie",  en: "Timeline"    },
  { href: "/reformes",           fr: "Réformes",     en: "Reforms"     },
  { href: "/glossaire",          fr: "Glossaire",    en: "Glossary"    },
];

const current = Astro.url.pathname;
---

<header class="bg-civic-950 text-amber-100">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex items-center justify-between h-14">

      <!-- Logotype -->
      <a href="/" class="flex items-center gap-2.5 group" aria-label="Accueil — La politique Française pour les nuls">
        <svg width="26" height="26" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <polygon points="16,3 29,9.5 29,22.5 16,29 3,22.5 3,9.5"
            stroke="oklch(57% 0.215 30)" stroke-width="1.5" fill="none"/>
          <text x="16" y="20.5" text-anchor="middle" font-size="10" font-weight="700"
            fill="oklch(57% 0.215 30)" font-family="Georgia,serif">RF</text>
        </svg>
        <span class="font-display text-sm font-semibold tracking-tight text-amber-100
                     group-hover:text-amber-300 transition-colors hidden sm:block">
          La politique Française pour les nuls
        </span>
        <span class="font-display text-sm font-semibold tracking-tight text-amber-100
                     group-hover:text-amber-300 transition-colors sm:hidden">
          FPFN
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center" aria-label="Navigation principale">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "px-3 py-2 text-xs font-medium tracking-wide rounded transition-colors",
              current.startsWith(item.href)
                ? "text-amber-100 bg-civic-800/60"
                : "text-amber-100/70 hover:text-amber-100 hover:bg-civic-800/40",
            ]}
          >
            <span class="fr-content">{item.fr}</span>
            <span class="en-content">{item.en}</span>
          </a>
        ))}
      </nav>

      <!-- Lang toggle + mobile button -->
      <div class="flex items-center gap-2">
        <button
          data-lang-toggle
          onclick="toggleLang()"
          class="text-xs font-semibold text-amber-100/80 border border-amber-100/25
                 px-2.5 py-2 rounded hover:bg-civic-800 hover:text-amber-100
                 transition-colors tabular-nums"
          aria-label="Switch language / Changer de langue"
        >EN</button>

        <button
          id="mobile-menu-btn"
          class="md:hidden text-amber-100/70 hover:text-amber-100 w-11 h-11 flex items-center justify-center rounded"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          onclick="
            var m = document.getElementById('mobile-menu');
            var open = m.classList.toggle('hidden');
            this.setAttribute('aria-expanded', String(!open));
          "
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true">
            <rect y="2" width="18" height="2" rx="1"/>
            <rect y="8" width="18" height="2" rx="1"/>
            <rect y="14" width="18" height="2" rx="1"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <nav id="mobile-menu" class="hidden md:hidden pb-3 grid grid-cols-2 gap-1"
         aria-label="Navigation mobile">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="px-3 py-2.5 text-sm text-amber-100/70 hover:text-amber-100
                 hover:bg-civic-800/50 rounded transition-colors"
        >
          <span class="fr-content">{item.fr}</span>
          <span class="en-content">{item.en}</span>
        </a>
      ))}
    </nav>
  </div>
</header>
