---
import Layout from "../layouts/Layout.astro";
import data from "../../content/reforms.json";

const reforms = (data as any).reforms as any[];

const areaLabel: Record<string, { fr: string; en: string }> = {
  retraites:       { fr: "Retraites",      en: "Pensions"     },
  travail:         { fr: "Travail",        en: "Labour"       },
  fiscal:          { fr: "Fiscal",         en: "Fiscal"       },
  "sante-social":  { fr: "Santé / Social", en: "Health/Social"},
  education:       { fr: "Education",      en: "Education"    },
  environnement:   { fr: "Environnement",  en: "Environment"  },
  institutionnel:  { fr: "Institutions",   en: "Institutions" },
  immigration:     { fr: "Immigration",    en: "Immigration"  },
};

const areaDesc: Record<string, { fr: string; en: string }> = {
  retraites:       { fr: "Âge de départ, régimes et durée de cotisation",               en: "Retirement age, pension systems and contribution periods" },
  travail:         { fr: "Code du travail, emploi et droits des salariés",              en: "Labour code, employment and workers' rights"              },
  fiscal:          { fr: "Impôts, fiscalité et redistribution",                         en: "Taxes, fiscal policy and redistribution"                  },
  "sante-social":  { fr: "Protection sociale, santé publique et aide sociale",          en: "Social protection, public health and welfare"             },
  education:       { fr: "Réformes scolaires et enseignement supérieur",                en: "School reforms and higher education"                     },
  environnement:   { fr: "Transition écologique et réglementation environnementale",    en: "Ecological transition and environmental regulation"       },
  institutionnel:  { fr: "Organisation des pouvoirs et révisions constitutionnelles",   en: "Organisation of powers and constitutional revisions"      },
  immigration:     { fr: "Accès au territoire, asile et nationalité",                   en: "Border access, asylum and nationality"                    },
};

const areaOrder = ["retraites", "travail", "fiscal", "sante-social", "education", "environnement", "institutionnel", "immigration"];

const controversyColor: Record<string, string> = {
  low:    "text-amber-700",
  medium: "text-amber-500",
  high:   "text-red-600",
};

const controversyLabel: Record<string, { fr: string; en: string }> = {
  low:    { fr: "Faible",  en: "Low"    },
  medium: { fr: "Moyen",   en: "Medium" },
  high:   { fr: "Élevé",   en: "High"   },
};
---

<Layout title="Réformes">

  <div class="bg-civic-950 px-5 py-10 md:py-12">
    <div class="max-w-3xl mx-auto">
      <h1 data-enter="1" class="font-display text-fluid-page font-bold text-amber-50 mb-4">
        <span class="fr-content">Les grandes réformes</span>
        <span class="en-content">Major reforms</span>
      </h1>
      <p data-enter="2" class="text-amber-300 text-sm max-w-xl leading-relaxed">
        <span class="fr-content">Les principales lois par domaine, avec les arguments pour et contre.</span>
        <span class="en-content">Major laws by area, with arguments for and against.</span>
      </p>
    </div>
  </div>

  <!-- Legend: explains area badges and controversy colour scale -->
  <div class="border-b border-amber-200 bg-amber-50/60">
    <div class="max-w-4xl mx-auto px-5 py-4 space-y-4">

      <!-- Areas -->
      <div>
        <p class="lbl text-amber-400 font-medium mb-3">
          <span class="fr-content">Domaines de réforme</span>
          <span class="en-content">Reform areas</span>
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {areaOrder.map((key) => (
            <div class="flex items-start gap-2">
              <span class="mt-[3px] flex-shrink-0 w-3 h-3 rounded-sm bg-amber-100 border border-amber-300" aria-hidden="true"></span>
              <div class="min-w-0">
                <p class="text-xs font-semibold text-amber-900 leading-tight">
                  <span class="fr-content">{areaLabel[key].fr}</span>
                  <span class="en-content">{areaLabel[key].en}</span>
                </p>
                <p class="text-[0.68rem] text-amber-500 leading-snug mt-0.5">
                  <span class="fr-content">{areaDesc[key].fr}</span>
                  <span class="en-content">{areaDesc[key].en}</span>
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Controversy scale -->
      <div>
        <p class="lbl text-amber-400 font-medium mb-3">
          <span class="fr-content">Niveau de controverse politique</span>
          <span class="en-content">Political controversy level</span>
        </p>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          <div class="flex items-center gap-2">
            <span class="text-amber-700 text-xs font-bold" aria-hidden="true">&#9632;</span>
            <div>
              <span class="text-xs font-semibold text-amber-900 fr-content">Faible</span>
              <span class="text-xs font-semibold text-amber-900 en-content">Low</span>
              <span class="text-[0.68rem] text-amber-500 ml-1.5 fr-content">Adopté sans mobilisation majeure</span>
              <span class="text-[0.68rem] text-amber-500 ml-1.5 en-content">Passed without major mobilisation</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-amber-500 text-xs font-bold" aria-hidden="true">&#9632;</span>
            <div>
              <span class="text-xs font-semibold text-amber-900 fr-content">Moyen</span>
              <span class="text-xs font-semibold text-amber-900 en-content">Medium</span>
              <span class="text-[0.68rem] text-amber-500 ml-1.5 fr-content">Débats et oppositions notables</span>
              <span class="text-[0.68rem] text-amber-500 ml-1.5 en-content">Notable debates and opposition</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-red-600 text-xs font-bold" aria-hidden="true">&#9632;</span>
            <div>
              <span class="text-xs font-semibold text-amber-900 fr-content">Élevé</span>
              <span class="text-xs font-semibold text-amber-900 en-content">High</span>
              <span class="text-[0.68rem] text-amber-500 ml-1.5 fr-content">Grèves, manifestations ou 49-3</span>
              <span class="text-[0.68rem] text-amber-500 ml-1.5 en-content">Strikes, protests or 49-3 bypass</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="max-w-4xl mx-auto px-5 py-8 md:py-12 space-y-8">
    {reforms.map((r, i) => (
      <article class="border border-amber-200 rounded-sm overflow-hidden js-card js-reveal" style={`transition-delay:${Math.min(i * 70, 350)}ms`}>

        <!-- Header -->
        <div class="bg-amber-50 border-b border-amber-200 px-5 py-4">
          <div class="flex flex-wrap items-start justify-between gap-2">
            <div>
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <span class="text-xs font-semibold text-amber-600 bg-amber-100 px-2 py-0.5 rounded-sm">
                  <span class="fr-content">{areaLabel[r.area]?.fr ?? r.area}</span>
                  <span class="en-content">{areaLabel[r.area]?.en ?? r.area}</span>
                </span>
                <span class="text-xs text-amber-500">{r.date_enacted}</span>
                {r.controversy_level && (
                  <span class:list={["text-xs font-medium", controversyColor[r.controversy_level] ?? "text-amber-500"]}>
                    <span class="fr-content">&#9632; {controversyLabel[r.controversy_level]?.fr ?? r.controversy_level}</span>
                    <span class="en-content">&#9632; {controversyLabel[r.controversy_level]?.en ?? r.controversy_level}</span>
                  </span>
                )}
              </div>
              <h2 class="font-display text-lg font-semibold text-amber-950">
                <span class="fr-content">{r.name_fr ?? r.name}</span>
                <span class="en-content">{r.name_en ?? r.name}</span>
              </h2>
              <p class="text-xs text-amber-500 mt-0.5">
                {r.president} · {r.prime_minister}
              </p>
            </div>
            {r.status === "needs-verification" && (
              <span class="verify-badge">&#9888;&#65039;</span>
            )}
          </div>
        </div>

        <!-- Body -->
        <div class="px-5 py-5 space-y-4">

          {(r.context_fr || r.context) && (
            <div>
              <p class="lbl font-medium text-amber-500 mb-2">
                <span class="fr-content">Contexte</span><span class="en-content">Context</span>
              </p>
              <p class="text-sm text-amber-800 leading-relaxed fr-content">{r.context_fr ?? r.context}</p>
              <p class="text-sm text-amber-800 leading-relaxed en-content">{r.context_en ?? r.context}</p>
            </div>
          )}

          {r.what_changed && r.what_changed.length > 0 && (
            <div>
              <p class="lbl font-medium text-amber-500 mb-2">
                <span class="fr-content">Ce qui a changé</span><span class="en-content">What changed</span>
              </p>
              <ul class="space-y-1">
                {(r.what_changed as any[]).map((item) => (
                  <li class="flex items-start gap-2 text-sm text-amber-800">
                    <span class="text-amber-400 flex-shrink-0 mt-0.5">—</span>
                    <span class="fr-content">{item.change_fr ?? item}</span>
                    <span class="en-content">{item.change_en ?? item}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- For/Against -->
          {r.perspectives && (
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="bg-amber-50 rounded-sm p-4 border border-amber-100">
                <p class="lbl font-semibold text-amber-600 mb-2">
                  <span class="fr-content">Arguments pour</span><span class="en-content">Arguments for</span>
                </p>
                {(r.perspectives.supporters_fr || r.perspectives.supporters) && (
                  <p class="text-xs text-amber-800 leading-relaxed fr-content">
                    {r.perspectives.supporters_fr ?? r.perspectives.supporters}
                  </p>
                )}
                {(r.perspectives.supporters_en || r.perspectives.supporters) && (
                  <p class="text-xs text-amber-800 leading-relaxed en-content">
                    {r.perspectives.supporters_en ?? r.perspectives.supporters}
                  </p>
                )}
              </div>
              <div class="bg-amber-50 rounded-sm p-4 border border-amber-100">
                <p class="lbl font-semibold text-amber-700 mb-2">
                  <span class="fr-content">Arguments contre</span><span class="en-content">Arguments against</span>
                </p>
                {(r.perspectives.opponents_fr || r.perspectives.opponents) && (
                  <p class="text-xs text-amber-800 leading-relaxed fr-content">
                    {r.perspectives.opponents_fr ?? r.perspectives.opponents}
                  </p>
                )}
                {(r.perspectives.opponents_en || r.perspectives.opponents) && (
                  <p class="text-xs text-amber-800 leading-relaxed en-content">
                    {r.perspectives.opponents_en ?? r.perspectives.opponents}
                  </p>
                )}
              </div>
            </div>
          )}

          {(r.current_status_fr || r.current_status) && (
            <p class="text-xs text-amber-600 italic">
              <span class="fr-content">{r.current_status_fr ?? r.current_status}</span>
              <span class="en-content">{r.current_status_en ?? r.current_status}</span>
            </p>
          )}
        </div>
      </article>
    ))}
  </div>

</Layout>
