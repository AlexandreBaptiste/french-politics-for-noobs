---
import Layout from "../../layouts/Layout.astro";
import rn from "../../../content/parties/rn.json";
import lfi from "../../../content/parties/lfi.json";
import renaissance from "../../../content/parties/renaissance.json";
import lr from "../../../content/parties/lr.json";
import ps from "../../../content/parties/ps.json";
import modem from "../../../content/parties/modem.json";
import others from "../../../content/parties/others.json";

export function getStaticPaths() {
  const main = [
    { id: "rn",          data: rn },
    { id: "lfi",         data: lfi },
    { id: "renaissance", data: renaissance },
    { id: "lr",          data: lr },
    { id: "ps",          data: ps },
    { id: "modem",       data: modem },
  ];
  const extra = (others.parties as any[]).map((p) => ({ id: p.party_id, data: p }));
  return [...main, ...extra].map(({ id, data }) => ({
    params: { id },
    props: { party: data },
  }));
}

const { party } = Astro.props as { party: any };
const { identity, ideology, history, history_summary, key_figures, legislative_record, program_2027 } = party;

const timeline: any[] = history?.timeline ?? [];

// Normalise key_policies to a uniform list
function normalisePolicies(policies: Record<string, any>) {
  const out: { key: string; fr: string | string[]; en: string | string[]; list: boolean; status?: string }[] = [];
  const skip = new Set<string>();
  for (const [k, v] of Object.entries(policies ?? {})) {
    if (k === "status" || skip.has(k)) continue;
    if (typeof v === "object" && v !== null && ("position_fr" in v || "position_en" in v)) {
      const isList = Array.isArray(v.position_fr) || Array.isArray(v.position_en);
      out.push({ key: k, fr: isList ? (v.position_fr ?? []) : (v.position_fr ?? ""), en: isList ? (v.position_en ?? []) : (v.position_en ?? ""), list: isList, status: v.status });
    } else if (typeof v === "string" && k.endsWith("_fr")) {
      const base = k.slice(0, -3);
      const enKey = base + "_en";
      skip.add(enKey);
      out.push({ key: base, fr: v, en: policies[enKey] ?? "", list: false });
    } else if (typeof v === "string" && !k.endsWith("_en") && !k.endsWith("_fr")) {
      out.push({ key: k, fr: v, en: v, list: false });
    }
  }
  return out;
}

const policies = normalisePolicies(program_2027?.key_policies ?? {});

const policyLabel: Record<string, { fr: string; en: string }> = {
  immigration:        { fr: "Immigration",    en: "Immigration"   },
  economy:            { fr: "Économie",       en: "Economy"       },
  economie:           { fr: "Économie",       en: "Economy"       },
  retraites:          { fr: "Retraites",      en: "Pensions"      },
  securite:           { fr: "Sécurité",       en: "Security"      },
  europe:             { fr: "Europe",         en: "Europe"        },
  europe_international: { fr: "Europe & International", en: "Europe & International" },
  energie:            { fr: "Énergie",        en: "Energy"        },
  fiscal:             { fr: "Fiscal",         en: "Fiscal"        },
  sante:              { fr: "Santé",          en: "Health"        },
  sante_education:    { fr: "Santé & Éducation", en: "Health & Education" },
  environnement:      { fr: "Environnement",  en: "Environment"   },
  education:          { fr: "Éducation",      en: "Education"     },
  institutions:       { fr: "Institutions",   en: "Institutions"  },
  travail:            { fr: "Travail",        en: "Labour"        },
  social:             { fr: "Social",         en: "Social"        },
  "sixieme-republique":{ fr: "6e République", en: "6th Republic"  },
  "key_issues":       { fr: "Enjeux clés",    en: "Key issues"    },
  "distinctive_positions": { fr: "Positions distinctives", en: "Distinctive positions" },
};

function label(key: string) {
  return policyLabel[key] ?? { fr: key, en: key };
}
---

<Layout title={identity.full_name_fr}>

  <div class="bg-civic-950 px-5 py-10 md:py-12">
    <div class="max-w-4xl mx-auto">

      <div data-enter="1" class="flex items-start gap-5">
        <!-- Color badge -->
        <div
          class="flex-shrink-0 w-12 h-12 sm:w-14 sm:h-14 rounded-sm flex items-center justify-center
                 text-white font-bold text-sm sm:text-base"
          style={`background:${identity.color};`}
          aria-hidden="true"
        >
          {identity.abbreviation.split("/")[0].trim().slice(0, 3)}
        </div>

        <div>
          <h1 class="font-display text-fluid-page font-bold text-amber-50">
            <span class="fr-content">{identity.full_name_fr}</span>
            <span class="en-content">{identity.full_name_en}</span>
          </h1>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-2 text-sm">
            <span class="text-amber-400">
              <span class="fr-content">Fondé en</span>
              <span class="en-content">Founded</span>
              {" "}{identity.founded}
            </span>
            <span class="text-amber-700 hidden sm:inline">·</span>
            <span class="text-amber-300">
              <span class="fr-content">{identity.position_on_spectrum_fr}</span>
              <span class="en-content">{identity.position_on_spectrum_en}</span>
            </span>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- Page body -->
  <div class="max-w-4xl mx-auto px-5 py-8 md:py-10 space-y-10 md:space-y-14">

    <!-- Ideology -->
    {ideology && (
      <section class="js-reveal" aria-labelledby="h-ideology">
        <h2 id="h-ideology" class="font-display text-xl font-semibold text-amber-950 mb-6 pb-2 border-b border-amber-200">
          <span class="fr-content">Idéologie et valeurs</span>
          <span class="en-content">Ideology and values</span>
        </h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <p class="lbl font-medium text-amber-500 mb-3">
              <span class="fr-content">Valeurs fondamentales</span>
              <span class="en-content">Core values</span>
            </p>
            <ul class="space-y-1.5">
              {(ideology.core_values_fr ?? []).map((v: string) => (
                <li class="fr-content flex items-start gap-2 text-sm text-amber-800">
                  <span class="text-amber-400 flex-shrink-0 mt-0.5">—</span>{v}
                </li>
              ))}
              {(ideology.core_values_en ?? []).map((v: string) => (
                <li class="en-content flex items-start gap-2 text-sm text-amber-800">
                  <span class="text-amber-400 flex-shrink-0 mt-0.5">—</span>{v}
                </li>
              ))}
            </ul>
          </div>
          {(ideology.eu_position_fr || ideology.internal_tensions_fr) && (
            <div class="space-y-5">
              {ideology.eu_position_fr && (
                <div>
                  <p class="lbl font-medium text-amber-500 mb-2">
                    <span class="fr-content">Position sur l'Europe</span>
                    <span class="en-content">Position on Europe</span>
                  </p>
                  <p class="text-sm text-amber-800 leading-relaxed fr-content">{ideology.eu_position_fr}</p>
                  <p class="text-sm text-amber-800 leading-relaxed en-content">{ideology.eu_position_en}</p>
                </div>
              )}
              {ideology.internal_tensions_fr && (
                <div class="bg-amber-50 border border-amber-200 rounded-sm p-4">
                  <p class="lbl font-medium text-amber-500 mb-2">
                    <span class="fr-content">Tensions internes</span>
                    <span class="en-content">Internal tensions</span>
                  </p>
                  <p class="text-sm text-amber-800 leading-relaxed fr-content">{ideology.internal_tensions_fr}</p>
                  <p class="text-sm text-amber-800 leading-relaxed en-content">{ideology.internal_tensions_en}</p>
                </div>
              )}
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Timeline or summary -->
    {timeline.length > 0 && (
      <section class="js-reveal" aria-labelledby="h-history">
        <h2 id="h-history" class="font-display text-xl font-semibold text-amber-950 mb-6 pb-2 border-b border-amber-200">
          <span class="fr-content">Historique</span>
          <span class="en-content">History</span>
        </h2>
        <div>
          {timeline.map((ev: any) => (
            <div class="flex gap-4">
              <div class="tl-year">{ev.year}</div>
              <div class="tl-body">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-sm text-amber-800 leading-relaxed fr-content">{ev.event_fr}</p>
                    <p class="text-sm text-amber-800 leading-relaxed en-content">{ev.event_en}</p>
                  </div>
                  {ev.status === "needs-verification" && (
                    <span class="verify-badge flex-shrink-0 mt-0.5">
                      <span class="fr-content">Source : <a href="https://fr.wikipedia.org/wiki/%C3%89lection_pr%C3%A9sidentielle_fran%C3%A7aise_de_2027" class="underline" target="_blank" rel="noopener noreferrer">Wikipédia</a></span>
                      <span class="en-content">Source: <a href="https://fr.wikipedia.org/wiki/%C3%89lection_pr%C3%A9sidentielle_fran%C3%A7aise_de_2027" class="underline" target="_blank" rel="noopener noreferrer">Wikipedia</a></span>
                    </span>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {!timeline.length && history_summary && (
      <section class="js-reveal" aria-labelledby="h-history2">
        <h2 id="h-history2" class="font-display text-xl font-semibold text-amber-950 mb-6 pb-2 border-b border-amber-200">
          <span class="fr-content">Historique</span>
          <span class="en-content">History</span>
        </h2>
        <p class="text-sm text-amber-800 leading-relaxed fr-content">{history_summary.summary_fr}</p>
        <p class="text-sm text-amber-800 leading-relaxed en-content">{history_summary.summary_en}</p>
        {history_summary.status === "needs-verification" && (
          <span class="verify-badge mt-3 inline-flex">
            <span class="fr-content">Source : <a href="https://fr.wikipedia.org/wiki/%C3%89lection_pr%C3%A9sidentielle_fran%C3%A7aise_de_2027" class="underline" target="_blank" rel="noopener noreferrer">Wikipédia</a></span>
            <span class="en-content">Source: <a href="https://fr.wikipedia.org/wiki/%C3%89lection_pr%C3%A9sidentielle_fran%C3%A7aise_de_2027" class="underline" target="_blank" rel="noopener noreferrer">Wikipedia</a></span>
          </span>
        )}
      </section>
    )}

    <!-- Key figures -->
    {key_figures && key_figures.length > 0 && (
      <section class="js-reveal" aria-labelledby="h-figures">
        <h2 id="h-figures" class="font-display text-xl font-semibold text-amber-950 mb-6 pb-2 border-b border-amber-200">
          <span class="fr-content">Figures clés</span>
          <span class="en-content">Key figures</span>
        </h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {(key_figures as any[]).map((fig) => (
            <div class="p-4 border border-amber-200 rounded-sm bg-amber-50/50">
              <div class="flex items-start justify-between gap-2 mb-1">
                <h3 class="font-display font-semibold text-amber-950 text-sm">{fig.name}</h3>
                <div class="flex items-center gap-1.5 flex-shrink-0">
                  {fig.is_leader && (
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded-sm text-[10px] font-semibold bg-amber-300 text-amber-950">
                      <span class="fr-content">Leader</span>
                      <span class="en-content">Leader</span>
                    </span>
                  )}
                  {fig.status === "needs-verification" && (
                    <span class="verify-badge flex-shrink-0">&#9888;&#65039;</span>
                  )}
                </div>
              </div>
              <p class="text-xs text-amber-700 leading-relaxed fr-content">{fig.role_fr}</p>
              <p class="text-xs text-amber-700 leading-relaxed en-content">{fig.role_en}</p>
              {fig.note_fr && (
                <p class="text-xs text-amber-500 mt-2 leading-relaxed italic fr-content">{fig.note_fr}</p>
              )}
              {fig.note_en && (
                <p class="text-xs text-amber-500 mt-2 leading-relaxed italic en-content">{fig.note_en}</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Legislative record -->
    {legislative_record && (
      <section class="js-reveal" aria-labelledby="h-record">
        <h2 id="h-record" class="font-display text-xl font-semibold text-amber-950 mb-6 pb-2 border-b border-amber-200">
          <span class="fr-content">Bilan législatif</span>
          <span class="en-content">Legislative record</span>
        </h2>
        {(legislative_record.note_fr ?? legislative_record.in_power_fr ?? legislative_record.major_reforms_fr) && (
          <p class="text-sm text-amber-800 leading-relaxed mb-5 fr-content">
            {legislative_record.note_fr ?? legislative_record.in_power_fr}
          </p>
        )}
        {(legislative_record.note_en ?? legislative_record.in_power_en) && (
          <p class="text-sm text-amber-800 leading-relaxed mb-5 en-content">
            {legislative_record.note_en ?? legislative_record.in_power_en}
          </p>
        )}

        {legislative_record.parliamentary_positions && (
          <div class="space-y-2">
            <p class="lbl font-medium text-amber-500 mb-3">
              <span class="fr-content">Votes cles</span>
              <span class="en-content">Key votes</span>
            </p>
            {(legislative_record.parliamentary_positions as any[]).map((pos) => (
              <div class="flex gap-3 p-3 bg-amber-50 rounded-sm border border-amber-100">
                <div class="flex-1">
                  <p class="text-xs font-semibold text-amber-900 mb-0.5 fr-content">{pos.subject_fr}</p>
                  <p class="text-xs font-semibold text-amber-900 mb-0.5 en-content">{pos.subject_en}</p>
                  <p class="text-xs text-amber-700 fr-content">{pos.position_fr}</p>
                  <p class="text-xs text-amber-700 en-content">{pos.position_en}</p>
                </div>
                {pos.status === "needs-verification" && (
                  <span class="verify-badge self-start flex-shrink-0">&#9888;&#65039;</span>
                )}
              </div>
            ))}
          </div>
        )}

        {legislative_record.major_reforms_when_in_power && (
          <div class="space-y-2">
            <p class="lbl font-medium text-amber-500 mb-3 fr-content">Reformes majeures</p>
            <p class="lbl font-medium text-amber-500 mb-3 en-content">Major reforms</p>
            {(legislative_record.major_reforms_when_in_power as any[]).map((r) => (
              <div class="flex items-center gap-3 p-3 bg-amber-50 rounded-sm border border-amber-100">
                <span class="font-display font-bold text-amber-400 text-sm w-10 flex-shrink-0">{r.year}</span>
                <p class="text-xs text-amber-800 fr-content">{r.reform_fr}</p>
                <p class="text-xs text-amber-800 en-content">{r.reform_fr}</p>
              </div>
            ))}
          </div>
        )}
      </section>
    )}

    <!-- 2027 Program -->
    {program_2027 && (
      <section class="js-reveal" aria-labelledby="h-program">
        <h2 id="h-program" class="font-display text-xl font-semibold text-amber-950 mb-5 pb-2 border-b border-amber-200">
          <span class="fr-content">Programme 2027</span>
          <span class="en-content">2027 Program</span>
        </h2>

        <!-- Snapshot warning -->
        <div class="bg-amber-100 border border-amber-300 rounded-sm p-4 mb-6">
          <p class="text-sm text-amber-800 leading-relaxed fr-content">{program_2027.note_fr}</p>
          <p class="text-sm text-amber-800 leading-relaxed en-content">{program_2027.note_en}</p>
        </div>

        {program_2027.presidential_candidate_fr && (
          <div class="mb-6">
            <p class="lbl font-medium text-amber-500 mb-1">
              <span class="fr-content">Candidat presidentiel</span>
              <span class="en-content">Presidential candidate</span>
            </p>
            <p class="font-display font-semibold text-amber-950 fr-content">{program_2027.presidential_candidate_fr}</p>
            <p class="font-display font-semibold text-amber-950 en-content">{program_2027.presidential_candidate_en}</p>
          </div>
        )}

        <div class="grid sm:grid-cols-2 gap-4">
          {policies.map((p) => (
            <div class="border border-amber-200 rounded-sm p-4">
              <div class="flex items-center justify-between gap-2 mb-3">
                <h3 class="lbl font-semibold text-amber-600">
                  <span class="fr-content">{label(p.key).fr}</span>
                  <span class="en-content">{label(p.key).en}</span>
                </h3>
                {p.status === "needs-verification" && (
                  <span class="verify-badge">&#9888;&#65039;</span>
                )}
              </div>
              {p.list ? (
                <ul class="space-y-1">
                  {(p.fr as string[]).map((item) => (
                    <li class="fr-content flex items-start gap-2 text-xs text-amber-800">
                      <span class="text-amber-400 flex-shrink-0 mt-0.5">·</span>{item}
                    </li>
                  ))}
                  {(p.en as string[]).map((item) => (
                    <li class="en-content flex items-start gap-2 text-xs text-amber-800">
                      <span class="text-amber-400 flex-shrink-0 mt-0.5">·</span>{item}
                    </li>
                  ))}
                </ul>
              ) : (
                <>
                  <p class="fr-content text-xs text-amber-800 leading-relaxed">{p.fr as string}</p>
                  <p class="en-content text-xs text-amber-800 leading-relaxed">{p.en as string}</p>
                </>
              )}
            </div>
          ))}
        </div>

        {program_2027.sources_for_verification?.length > 0 && (
          <div class="mt-5 text-xs text-amber-500">
            <span class="fr-content font-medium">Sources : </span>
            <span class="en-content font-medium">Sources: </span>
            {(program_2027.sources_for_verification as string[]).map((s) => {
              const url = s.match(/https?:\/\/\S+/)?.[0];
              return url ? (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block mt-0.5 text-amber-400 hover:text-amber-600 underline underline-offset-2 transition-colors break-all"
                >{url}</a>
              ) : (
                <span class="block mt-0.5">{s}</span>
              );
            })}
            <a
              href="https://fr.wikipedia.org/wiki/%C3%89lection_pr%C3%A9sidentielle_fran%C3%A7aise_de_2027"
              target="_blank"
              rel="noopener noreferrer"
              class="block mt-0.5 text-amber-400 hover:text-amber-600 underline underline-offset-2 transition-colors"
            >Wikipédia — Élection présidentielle française de 2027</a>
          </div>
        )}
      </section>
    )}

  </div>

</Layout>
