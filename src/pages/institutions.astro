---
import Layout from "../layouts/Layout.astro";
import data from "../../content/institutions.json";

const institutions = data.institutions as any[];
const checksAndBalances = (data as any).checks_and_balances as any[];
const legislativeProcess = (data as any).legislative_process as any;

const branchColor: Record<string, string> = {
  executive: "bg-amber-500",
  legislative: "bg-amber-700",
  judiciary: "bg-amber-800",
  territorial: "bg-amber-300",
};
const branchLabel: Record<string, { fr: string; en: string }> = {
  executive:   { fr: "Exécutif",     en: "Executive"   },
  legislative: { fr: "Législatif",   en: "Legislative" },
  judiciary:   { fr: "Judiciaire",   en: "Judiciary"   },
  territorial: { fr: "Territorial",  en: "Territorial" },
};
const branchDesc: Record<string, { fr: string; en: string }> = {
  executive:   { fr: "Dirige et applique la politique nationale", en: "Leads and implements national policy" },
  legislative: { fr: "Vote les lois et contrôle le gouvernement", en: "Passes laws and oversees the government" },
  judiciary:   { fr: "Garantit l'État de droit et contrôle la constitutionnalité", en: "Upholds the rule of law and constitutional review" },
  territorial: { fr: "Gouverne les collectivités locales (régions, communes)", en: "Governs local authorities (regions, communes)" },
};
const branchOrder = ["executive", "legislative", "judiciary", "territorial"];
---

<Layout title="Institutions">

  <div class="bg-civic-950 px-5 py-10 md:py-12">
    <div class="max-w-3xl mx-auto">
      <h1 data-enter="1" class="font-display text-fluid-page font-bold text-amber-50 mb-4">
        <span class="fr-content">Les institutions françaises</span>
        <span class="en-content">French institutions</span>
      </h1>
      <p data-enter="2" class="text-amber-300 text-sm max-w-xl leading-relaxed">
        <span class="fr-content">Comment est organisé le gouvernement français : pouvoirs, rôles et équilibres.</span>
        <span class="en-content">How the French government is organised: powers, roles and balances.</span>
      </p>
    </div>
  </div>

  <!-- Branch legend: explains what each badge category means -->
  <div class="border-b border-amber-200 bg-amber-50/60">
    <div class="max-w-5xl mx-auto px-5 py-4">
      <p class="lbl text-amber-400 font-medium mb-3">
        <span class="fr-content">Les pouvoirs</span>
        <span class="en-content">Branches of power</span>
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {branchOrder.map((key) => (
          <div class="flex items-start gap-2.5">
            <span class:list={[
              "mt-[3px] flex-shrink-0 w-3 h-3 rounded-sm",
              branchColor[key]
            ]} aria-hidden="true"></span>
            <div class="min-w-0">
              <p class="text-xs font-semibold text-amber-900 leading-tight">
                <span class="fr-content">{branchLabel[key].fr}</span>
                <span class="en-content">{branchLabel[key].en}</span>
              </p>
              <p class="text-[0.68rem] text-amber-500 leading-snug mt-0.5">
                <span class="fr-content">{branchDesc[key].fr}</span>
                <span class="en-content">{branchDesc[key].en}</span>
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-5 py-8 md:py-12 space-y-6">
    {institutions.map((inst, i) => (
      <article class="border border-amber-200 rounded-sm overflow-hidden js-card js-reveal" style={`transition-delay:${i * 80}ms`}>

        <!-- Institution header -->
        <div class="flex items-center gap-3 px-5 py-4 bg-amber-50 border-b border-amber-200">
          <span class:list={[
            "text-xs font-semibold text-white px-2 py-0.5 rounded-sm",
            branchColor[inst.branch] ?? "bg-amber-500"
          ]}>
            <span class="fr-content">{branchLabel[inst.branch]?.fr ?? inst.branch}</span>
            <span class="en-content">{branchLabel[inst.branch]?.en ?? inst.branch}</span>
          </span>
          <h2 class="font-display text-lg font-semibold text-amber-950 flex-1 min-w-0">
            <span class="fr-content">{inst.name_fr}</span>
            <span class="en-content">{inst.name_en}</span>
          </h2>
          {inst.status === "needs-verification" && (
            <span class="verify-badge ml-auto">&#9888;&#65039;</span>
          )}
        </div>

        <!-- Role -->
        <div class="px-5 py-5">
          <p class="text-sm text-amber-800 leading-relaxed mb-4 fr-content">{inst.role_fr}</p>
          <p class="text-sm text-amber-800 leading-relaxed mb-4 en-content">{inst.role_en}</p>

          <div class="grid sm:grid-cols-3 gap-4 text-xs">
            {inst.composition?.members && (
              <div>
                <p class="text-amber-500 font-medium mb-1 fr-content">Composition</p>
                <p class="text-amber-500 font-medium mb-1 en-content">Composition</p>
                <p class="text-amber-800 fr-content">{inst.composition.members} {inst.composition.title_fr}</p>
                <p class="text-amber-800 en-content">{inst.composition.members} {inst.composition.title_en ?? inst.composition.title_fr}</p>
              </div>
            )}
            {inst.selection?.method_fr && (
              <div>
                <p class="text-amber-500 font-medium mb-1 fr-content">Mode de désignation</p>
                <p class="text-amber-500 font-medium mb-1 en-content">Selection method</p>
                <p class="text-amber-800 fr-content">{inst.selection.method_fr}</p>
                <p class="text-amber-800 en-content">{inst.selection.method_en}</p>
              </div>
            )}
            {inst.term?.duration_years && (
              <div>
                <p class="text-amber-500 font-medium mb-1 fr-content">Durée du mandat</p>
                <p class="text-amber-500 font-medium mb-1 en-content">Term length</p>
                <p class="text-amber-800">{inst.term.duration_years} ans / years · {inst.term.name_fr ?? ""}</p>
              </div>
            )}
          </div>

          {inst.key_powers && inst.key_powers.length > 0 && (
            <div class="mt-4">
              <p class="lbl font-medium text-amber-500 mb-2">
                <span class="fr-content">Pouvoirs clés</span>
                <span class="en-content">Key powers</span>
              </p>
              <ul class="space-y-1">
                {(inst.key_powers as any[]).slice(0, 6).map((kp) => (
                  <li class="flex items-start gap-2 text-xs text-amber-800">
                    <span class="text-amber-400 flex-shrink-0 mt-0.5">{kp.article ? `[${kp.article}]` : "·"}</span>
                    <span class="fr-content">{kp.power_fr}</span>
                    <span class="en-content">{kp.power_en}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </article>
    ))}

    <!-- Legislative process -->
    {legislativeProcess?.steps && (
      <section class="mt-8">
        <h2 class="font-display text-xl font-semibold text-amber-950 mb-6 pb-2 border-b border-amber-200">
          <span class="fr-content">Le processus législatif</span>
          <span class="en-content">The legislative process</span>
        </h2>
        <div class="space-y-0">
          {(legislativeProcess.steps as any[]).map((step: any, i: number) => (
            <div class="flex gap-4">
              <div class="flex flex-col items-center">
                <div class="w-7 h-7 rounded-full bg-amber-500 text-white text-xs font-bold flex items-center justify-center flex-shrink-0">
                  {i + 1}
                </div>
                {i < legislativeProcess.steps.length - 1 && (
                  <div class="w-px flex-1 bg-amber-200 my-1"></div>
                )}
              </div>
              <div class="pb-5 pt-0.5">
                <p class="text-sm font-semibold text-amber-900 fr-content">{step.step_fr ?? step.name_fr ?? step.title_fr}</p>
                <p class="text-sm font-semibold text-amber-900 en-content">{step.step_en ?? step.name_en ?? step.title_en}</p>
                {(step.description_fr || step.detail_fr) && (
                  <p class="text-xs text-amber-600 mt-0.5 fr-content">{step.description_fr ?? step.detail_fr}</p>
                )}
                {(step.description_en || step.detail_en) && (
                  <p class="text-xs text-amber-600 mt-0.5 en-content">{step.description_en ?? step.detail_en}</p>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>

</Layout>
