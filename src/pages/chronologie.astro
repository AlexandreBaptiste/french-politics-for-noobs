---
import Layout from "../layouts/Layout.astro";
import data from "../../content/timeline.json";

const events = (data as any).events as any[];

const typeColor: Record<string, string> = {
  election:          "bg-amber-500",
  government:        "bg-amber-700",
  constitutional:    "bg-amber-800",
  "social-movement": "bg-amber-400",
  crisis:            "bg-red-700",
  scandal:           "bg-amber-600",
  law:               "bg-amber-600",
  attack:            "bg-red-800",
  international:     "bg-amber-300",
};

const typeLabel: Record<string, { fr: string; en: string }> = {
  election:          { fr: "Election",         en: "Election"        },
  government:        { fr: "Gouvernement",     en: "Government"      },
  constitutional:    { fr: "Constitutionnel",  en: "Constitutional"  },
  "social-movement": { fr: "Mouvement social", en: "Social movement" },
  crisis:            { fr: "Crise",            en: "Crisis"          },
  scandal:           { fr: "Scandale",         en: "Scandal"         },
  law:               { fr: "Loi",              en: "Law"             },
  attack:            { fr: "Attentat",         en: "Attack"          },
  international:     { fr: "International",    en: "International"   },
};

const typeDesc: Record<string, { fr: string; en: string }> = {
  election:          { fr: "Scrutins présidentiels, législatifs et européens",       en: "Presidential, legislative and European elections"         },
  government:        { fr: "Formations, démissions et transformations gouvernementales", en: "Government formations, resignations and changes"          },
  constitutional:    { fr: "Réformes institutionnelles et referendums",               en: "Institutional reforms and referendums"                    },
  "social-movement": { fr: "Grèves, manifestations et mobilisations citoyennes",     en: "Strikes, protests and citizen mobilizations"             },
  crisis:            { fr: "Urgences sanitaires, économiques ou sécuritaires",       en: "Health, economic or security emergencies"                },
  scandal:           { fr: "Affaires judiciaires et politiques",                     en: "Legal and political affairs"                             },
  law:               { fr: "Textes législatifs majeurs et réformes",                 en: "Major legislation and structural reforms"                },
  attack:            { fr: "Attentats et actes terroristes",                         en: "Terrorist attacks and acts of political violence"        },
  international:     { fr: "Crises et décisions à portée internationale",            en: "International crises and decisions"                     },
};

const typeOrder = ["election", "government", "constitutional", "law", "social-movement", "crisis", "scandal", "attack", "international"];

const uniqueTypes = [...new Set(events.map((e: any) => e.type as string))];

const _seen = new Set<string>();
const eventsWithMeta = events.map((ev: any) => {
  const year = (ev.date as string).slice(0, 4);
  const isFirstOfYear = !_seen.has(year);
  _seen.add(year);
  return { ...ev, year, isFirstOfYear };
});
---

<Layout title="Chronologie">

  <div class="bg-civic-950 px-5 py-10 md:py-12">
    <div class="max-w-3xl mx-auto">
      <h1 data-enter="1" class="font-display text-fluid-page font-bold text-amber-50 mb-4">
        <span class="fr-content">Chronologie politique</span>
        <span class="en-content">Political timeline</span>
      </h1>
      <p data-enter="2" class="text-amber-300 text-sm max-w-xl leading-relaxed">
        <span class="fr-content">Les événements majeurs de la politique française depuis 1995.</span>
        <span class="en-content">Major events in French politics since 1995.</span>
      </p>
    </div>
  </div>

  <!-- Event type legend: explains what each badge category means -->
  <div class="border-b border-amber-200 bg-amber-50/60">
    <div class="max-w-3xl mx-auto px-5 py-4">
      <p class="lbl text-amber-400 font-medium mb-3">
        <span class="fr-content">Types d'événements</span>
        <span class="en-content">Event types</span>
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {typeOrder.map((key) => (
          <div class="flex items-start gap-2.5">
            <span class:list={[
              "mt-[3px] flex-shrink-0 w-3 h-3 rounded-sm",
              typeColor[key]
            ]} aria-hidden="true"></span>
            <div class="min-w-0">
              <p class="text-xs font-semibold text-amber-900 leading-tight">
                <span class="fr-content">{typeLabel[key].fr}</span>
                <span class="en-content">{typeLabel[key].en}</span>
              </p>
              <p class="text-[0.68rem] text-amber-500 leading-snug mt-0.5">
                <span class="fr-content">{typeDesc[key].fr}</span>
                <span class="en-content">{typeDesc[key].en}</span>
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-5 py-8 md:py-12">

    <!-- Type filters -->
    <div class="mb-8">
      <div
        class="flex flex-wrap gap-2"
        id="type-filters"
        role="group"
        aria-label="Filtrer par type / Filter by type"
      >
        <button
          class="type-btn px-3 py-1.5 text-xs font-medium border rounded-full transition-colors border-amber-500 bg-amber-500 text-white"
          data-type="all"
          aria-pressed="true"
        >
          <span class="fr-content">Tous</span><span class="en-content">All</span>
        </button>
        {uniqueTypes.map((type) => (
          <button
            class="type-btn px-3 py-1.5 text-xs font-medium border rounded-full transition-colors border-amber-300 text-amber-700 hover:border-amber-500 hover:bg-amber-50"
            data-type={type}
            aria-pressed="false"
          >
            <span class="fr-content">{typeLabel[type]?.fr ?? type}</span>
            <span class="en-content">{typeLabel[type]?.en ?? type}</span>
          </button>
        ))}
      </div>
      <p class="mt-3 text-xs text-amber-500">
        <span id="count-num">{events.length}</span>
        <span class="fr-content"> événements</span>
        <span class="en-content"> events</span>
      </p>
    </div>

    <!-- Timeline -->
    <div id="timeline-list">
      {eventsWithMeta.map((ev) => (
        <div
          class="tl-event flex gap-4"
          data-type={ev.type}
          data-year={ev.year}
        >
          <div class="tl-year tl-year-cell">{ev.isFirstOfYear ? ev.year : ''}</div>
          <div class="tl-body">
            <div class="flex items-start gap-2 mb-1 flex-wrap">
              <span class:list={[
                "text-xs text-white px-2 py-0.5 rounded-sm font-medium flex-shrink-0",
                typeColor[ev.type] ?? "bg-amber-500",
              ]}>
                <span class="fr-content">{typeLabel[ev.type]?.fr ?? ev.type}</span>
                <span class="en-content">{typeLabel[ev.type]?.en ?? ev.type}</span>
              </span>
              <h3 class="font-display font-semibold text-amber-950 text-sm flex-1 min-w-0">
                <span class="fr-content">{ev.title_fr}</span>
                <span class="en-content">{ev.title_en}</span>
              </h3>
              {ev.status === "needs-verification" && (
                <span class="verify-badge flex-shrink-0">&#9888;&#65039;</span>
              )}
            </div>
            <p class="text-sm text-amber-800 leading-relaxed fr-content">{ev.description_fr}</p>
            <p class="text-sm text-amber-800 leading-relaxed en-content">{ev.description_en}</p>
            {ev.political_impact_fr && (
              <p class="text-xs text-amber-500 italic mt-1 fr-content">{ev.political_impact_fr}</p>
            )}
            {ev.political_impact_en && (
              <p class="text-xs text-amber-500 italic mt-1 en-content">{ev.political_impact_en}</p>
            )}
          </div>
        </div>
      ))}
    </div>

    <p id="no-results" class="hidden text-center text-amber-600 py-16 text-sm">
      <span class="fr-content">Aucun événement pour ce filtre.</span>
      <span class="en-content">No events for this filter.</span>
    </p>

  </div>

  <script>
    const typeBtns  = document.querySelectorAll<HTMLButtonElement>('.type-btn');
    const eventRows = document.querySelectorAll<HTMLElement>('.tl-event');
    const noResults = document.getElementById('no-results')!;
    const countNum  = document.getElementById('count-num')!;
    const active    = new Set<string>();

    function fixYearLabels() {
      const visible = [...eventRows].filter(r => !r.classList.contains('hidden'));
      const seen = new Set<string>();
      visible.forEach(row => {
        const year = row.dataset.year!;
        const cell = row.querySelector<HTMLElement>('.tl-year-cell')!;
        if (!seen.has(year)) {
          seen.add(year);
          cell.textContent = year;
        } else {
          cell.textContent = '';
        }
      });
    }

    function applyFilter() {
      let count = 0;
      eventRows.forEach(row => {
        const show = active.size === 0 || active.has(row.dataset.type!);
        row.classList.toggle('hidden', !show);
        if (show) count++;
      });
      fixYearLabels();
      countNum.textContent = String(count);
      noResults.classList.toggle('hidden', count > 0);
    }

    function syncButtons() {
      typeBtns.forEach(btn => {
        const t   = btn.dataset.type!;
        const on  = t === 'all' ? active.size === 0 : active.has(t);
        btn.classList.toggle('border-amber-500', on);
        btn.classList.toggle('bg-amber-500',     on);
        btn.classList.toggle('text-white',        on);
        btn.classList.toggle('border-amber-300',  !on);
        btn.classList.toggle('text-amber-700',    !on);
        btn.setAttribute('aria-pressed', String(on));
      });
    }

    typeBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const t = btn.dataset.type!;
        if (t === 'all') {
          active.clear();
        } else {
          active.has(t) ? active.delete(t) : active.add(t);
        }
        syncButtons();
        applyFilter();
      });
    });
  </script>

</Layout>
